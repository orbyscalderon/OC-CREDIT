# =============================================================================
# OC CREDIT FRONTEND - Variables de Entorno
# =============================================================================
#
# En desarrollo y producción el proxy /api está configurado en dos niveles:
#   - Desarrollo: vite.config.ts proxea /api → http://localhost:4000
#   - Producción: vercel.json proxea /api/* → backend desplegado
#
# Las siguientes variables son opcionales: si no se definen, los botones de
# Google Sign-In y Google Pay simplemente no aparecen en la UI.

# --- Google Sign In with Google ---
# Obtener en: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Añadir en Authorized JavaScript origins: https://tu-app.vercel.app
# Añadir en Authorized redirect URIs: https://tu-app.vercel.app (no necesita redirect URI extra)
VITE_GOOGLE_CLIENT_ID=CAMBIAR_POR_CLIENT_ID_DE_GOOGLE

# --- Google Pay ---
# TEST no requiere credenciales reales — muestra el botón con tarjeta de prueba.
# Para PRODUCTION necesitas aprobar tu comercio en pay.google.com/business/console
VITE_GOOGLE_PAY_ENV=TEST
VITE_GOOGLE_PAY_MERCHANT_ID=BCR2DN4TZHFHWT6I   # reemplazar con tu merchant ID real en PRODUCTION
VITE_PLACETOPAY_MERCHANT_ID=                     # tu merchant ID de PlacetoPay (gateway)
