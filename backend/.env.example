# NUNCA commitear el archivo .env real. Solo este .env.example
# =============================================================================

# --- Servidor ---
NODE_ENV=production                 # development | production
PORT=4000
API_PREFIX=api

# --- CORS ---
# Desarrollo: http://localhost:3000,http://localhost:5173
# Producción: solo la URL del frontend desplegado
ALLOWED_ORIGINS=https://tu-app.vercel.app

# --- Base de Datos ---
# ⚠️  Si usas Supabase, utiliza el pooler IPv4 (no la conexión directa).
# Usuario del pooler tiene formato: postgres.TU_PROJECT_REF
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=oc_credit_db
DATABASE_USER=postgres
DATABASE_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
DATABASE_SCHEMA=public
DATABASE_SSL=false                  # true en producción con Supabase
DATABASE_MAX_CONNECTIONS=10

# --- JWT ---
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_A_64_BYTES_HEX_ALEATORIO
JWT_EXPIRATION=8h
JWT_REFRESH_SECRET=CAMBIAR_A_64_BYTES_HEX_ALEATORIO_DISTINTO
JWT_REFRESH_EXPIRATION=30d

# --- Super Admin (JWT separado — tabla super_admins) ---
# Sin este valor el guard rechaza TODO acceso a /super-admin (fail closed)
SUPER_ADMIN_JWT_SECRET=CAMBIAR_A_64_BYTES_HEX_ALEATORIO_DISTINTO

# --- WhatsApp (Meta Cloud API) ---
# Obtener en: developers.facebook.com → WhatsApp → API Setup
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- Pasarelas de Pago (webhooks HMAC-SHA256) ---
# Dejar vacío para deshabilitar. Pegar el secret que asigna cada proveedor.
AZUL_WEBHOOK_SECRET=
PLACETOPAY_WEBHOOK_SECRET=

# --- Google OAuth (Sign In with Google) ---
# Obtener en: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Tipo: Web Application. Añadir en Authorized JavaScript origins: tu frontend URL.
GOOGLE_CLIENT_ID=CAMBIAR_POR_CLIENT_ID_DE_GOOGLE

# --- Google Pay (pagos de planes) ---
# GOOGLE_PAY_ENV: TEST para desarrollo/staging, PRODUCTION cuando esté listo para cobrar
GOOGLE_PAY_ENV=TEST

# --- PlacetoPay (procesador de Google Pay en producción) ---
# Obtener en el portal de comercios de PlacetoPay.
# Solo se usan cuando GOOGLE_PAY_ENV=PRODUCTION
PLACETOPAY_LOGIN=
PLACETOPAY_SECRET_KEY=
PLACETOPAY_API_URL=https://checkout.redirection.test
