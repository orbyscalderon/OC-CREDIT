# NUNCA commitear el archivo .env real. Solo .env.example
# =============================================================================

# --- Servidor ---
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173,https://app.tudominio.com

# --- Base de Datos ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=oc_credit_db
DATABASE_USER=oc_credit_user
DATABASE_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DATABASE_SCHEMA=public
DATABASE_SSL=false
DATABASE_MAX_CONNECTIONS=20

# --- JWT ---
JWT_SECRET=CHANGE_THIS_TO_A_64_CHAR_RANDOM_STRING
JWT_EXPIRATION=8h
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_64_CHAR_RANDOM_STRING
JWT_REFRESH_EXPIRATION=30d

# --- Super Admin ---
# Secreto del JWT propio de /super-admin/* (login con email+password en la
# tabla super_admins, no comparte secreto con el JWT de tenants). Sin esta
# variable el guard rechaza TODO acceso (fail closed) — no hay valor por defecto.
# Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SUPER_ADMIN_JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_STRING

# --- Almacenamiento de archivos (fotos, logos) ---
STORAGE_PROVIDER=local              # local | s3 | cloudinary
STORAGE_LOCAL_PATH=./uploads
# AWS S3
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Backups ---
BACKUP_CRON=0 */6 * * *             # Cada 6 horas
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/var/backups/oc-credit

# --- Webhooks Pasarelas de Pago ---
AZUL_MERCHANT_ID=
AZUL_MERCHANT_NAME=
AZUL_AUTH_TOKEN=
PLACETOPAY_LOGIN=
PLACETOPAY_SECRET_KEY=
PLACETOPAY_URL=https://secure.placetopay.com

# --- Alertas ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=admin@ocmoongroup.com
