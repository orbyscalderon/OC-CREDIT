# NUNCA commitear el archivo .env real. Solo este .env.example
# =============================================================================

# --- Servidor ---
NODE_ENV=production                 # development | production
PORT=4000
API_PREFIX=api

# --- CORS ---
# Desarrollo: http://localhost:3000,http://localhost:3002,http://localhost:5173
# Producción: solo la URL de Vercel
ALLOWED_ORIGINS=https://oc-credit.vercel.app

# --- Base de Datos (Supabase via IPv4 pooler) ---
# ⚠️  Usar el pooler IPv4 — la conexión directa (db.*.supabase.co) solo tiene IPv6
# Host pooler: aws-0-[region].pooler.supabase.com
# Usuario pooler: postgres.[project-ref]  (NO solo "postgres")
DATABASE_HOST=aws-0-us-east-1.pooler.supabase.com
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres.TU_PROJECT_REF
DATABASE_PASSWORD=TU_DB_PASSWORD
DATABASE_SCHEMA=public
DATABASE_SSL=true                   # true = rejectUnauthorized:false (req. para pooler)
DATABASE_MAX_CONNECTIONS=10

# --- JWT (generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CAMBIAR_A_64_BYTES_HEX_ALEATORIO
JWT_EXPIRATION=8h
JWT_REFRESH_SECRET=CAMBIAR_A_64_BYTES_HEX_ALEATORIO_DISTINTO
JWT_REFRESH_EXPIRATION=30d

# --- Super Admin (JWT separado — tabla super_admins) ---
# Sin este valor el guard rechaza TODO acceso al panel /super-admin (fail closed)
SUPER_ADMIN_JWT_SECRET=CAMBIAR_A_64_BYTES_HEX_ALEATORIO_DISTINTO

# --- WhatsApp (Meta Cloud API) ---
# Obtener en: developers.facebook.com → WhatsApp → API Setup
# Dejar vacío para deshabilitar notificaciones WhatsApp
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- Pasarelas de Pago (webhooks HMAC-SHA256) ---
# Dejar vacío mientras los pagos se procesen en efectivo.
# Al activar una pasarela, pegar el webhook secret que el proveedor asigna.
AZUL_WEBHOOK_SECRET=
PLACETOPAY_WEBHOOK_SECRET=
